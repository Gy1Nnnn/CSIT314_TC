# Copy to .env for local production-like testing (optional).
# GitHub Actions CD can set VITE_API_BASE_URL as an encrypted secret.

# Full origin of the Flask API (no trailing slash), e.g. https://courage-api.onrender.com
# Leave unset for local dev — the Vite dev server proxies /api to http://127.0.0.1:5000.
# VITE_API_BASE_URL=

# Only used at build time for GitHub Pages under /repo-name/. CI sets this automatically.
# VITE_BASE=
